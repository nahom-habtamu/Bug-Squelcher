generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bug {
  id               String   @id @default(uuid())
  title            String
  stepsToReproduce String
  severity         Severity
  status           Status   @default(Open)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum Severity {
  P0
  P1
  P2
  P3
}

enum Status {
  Open
  InProgress
  WorksOnMyMachine
}
